# abstract-backend-mcp
PROJECT_NAME=my-project
ENVIRONMENT=development

# FastAPI
FASTAPI_APP_PATH=app.main:app
ENABLE_FASTAPI_TOOLS=true
ALLOW_FASTAPI_RUNTIME_IMPORTS=false

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=mydb
ENABLE_MONGODB_TOOLS=true
MONGODB_SAMPLE_MAX_DOCUMENTS=20

# Stackraise
ENABLE_STACKRAISE_TOOLS=false
STACKRAISE_CONTEXT_MODE=hybrid
ALLOW_RUNTIME_CONTEXT_IMPORTS=false
ENABLE_DEEP_STACKRAISE_CONTEXT=true
MAX_SOURCE_CHUNK_LINES=200
MAX_TOTAL_SNAPSHOT_ITEMS=500
STACKRAISE_SEARCH_MAX_PATTERN_LENGTH=200
STACKRAISE_SEARCH_TIMEOUT_MS=500
STACKRAISE_SEARCH_MAX_SCANNED_LINES=20000
STACKRAISE_CONTEXT_CACHE_TTL_SECONDS=30
STACKRAISE_CONTEXT_CACHE_MAX_ENTRIES=32
STACKRAISE_CONTEXT_FINGERPRINT_TTL_SECONDS=1

# Write controls
ALLOW_WRITE_OPERATIONS=false
REQUIRE_WRITE_CONFIRMATION=true
ALLOWED_WRITE_COLLECTIONS=[]

# Security
REDACT_SENSITIVE_FIELDS=true
INCLUDE_FRONTEND_CONTEXT=false
MAX_OUTPUT_ITEMS=50
