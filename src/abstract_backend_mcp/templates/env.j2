# abstract-backend-mcp
PROJECT_NAME={{ project_name }}
ENVIRONMENT=development
{% if fastapi_app_path %}
FASTAPI_APP_PATH={{ fastapi_app_path }}
{% endif %}
ENABLE_FASTAPI_TOOLS={{ has_fastapi | lower }}

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME={{ project_name }}
ENABLE_MONGODB_TOOLS={{ has_mongodb | lower }}

STACKRAISE_ENABLED={{ has_stackraise | lower }}
ENABLE_STACKRAISE_TOOLS={{ has_stackraise | lower }}
STACKRAISE_CONTEXT_MODE=hybrid

ALLOW_WRITE_OPERATIONS=false
REQUIRE_WRITE_CONFIRMATION=true
ALLOWED_WRITE_COLLECTIONS=[]

REDACT_SENSITIVE_FIELDS=true
INCLUDE_FRONTEND_CONTEXT=false
MAX_OUTPUT_ITEMS=50
